@page "/services"
@inject IStringLocalizer<ServicesAndPrices> L
@using System.Globalization

<h2 class="neon-title page-title text-center">@L["Title"]</h2>
<div class="container mb-5 services-page">
    <div class="row justify-content-center">
        @for (int i = 0; i < services.Count; i++)
        {
            var service = services[i];
            var isLast = i == services.Count - 1;

            <div class="col-md-4 @(isLast ? "mb-md-0" : "mb-4 mb-md-0")">
                <div class="card service-card h-100 d-flex flex-column justify-content-between">
                    <div class="card-body">
                        <h4 class="card-title neon-title text-center mb-4" style="font-size: 1.5rem;">
                            @service.Name
                        </h4>
                        <p class="card-text">
                            @service.Desc
                        </p>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0 pb-4 px-4 text-center">
                        <span class="service-price">
                            @if (service.Price != null && service.Price.Contains("BYN") && CultureInfo.CurrentCulture.Name.StartsWith("ru"))
                            {
                                @service.Price.Replace("BYN", "").Trim()
                                <img src="images/byn.svg" class="byn-icon-services" alt="BYN" />
                            }
                            else
                            {
                                @service.Price
                            }
                        </span>
                    </div>
                </div>
            </div>
        }

        <div class="col-12">
            <div class="text-center mt-4">
                <a href="/request" class="btn btn-primary px-5 py-2">@L["BookButton"]</a>
            </div>
        </div>
    </div>
</div>

@code {
    private List<ServiceItem> services = new();

    protected override void OnInitialized()
    {
        // Теперь подтягиваем данные из локализатора ServicesAndPrices
        services = new List<ServiceItem>
        {
            new ServiceItem { Name = L["AnimName"], Desc = L["AnimDesc"], Price = L["AnimPrice"] },
            new ServiceItem { Name = L["BeamName"], Desc = L["BeamDesc"], Price = L["BeamPrice"] },
            new ServiceItem { Name = L["CombName"], Desc = L["CombDesc"], Price = L["CombPrice"] }
        };
    }

    public class ServiceItem
    {
        public string? Name { get; set; }
        public string? Desc { get; set; }
        public string? Price { get; set; }
    }
}