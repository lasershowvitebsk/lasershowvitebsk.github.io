@using LaserShowSite.Services
@using Microsoft.Extensions.Localization
@using System.Text.RegularExpressions
@inject ChatService ChatService
@inject IJSRuntime JsRuntime
@inject IStringLocalizer<ChatWidget> L

<div class="chat-widget">
    <!-- Кнопка-триггер -->
    <button class="chat-toggle" @onclick="ToggleChat">
        @if (isOpen)
        {
            <span>✕</span>
        }
        else
        {
            <span>💬</span>
        }
    </button>

    <!-- Окно чата (Локализованное) -->
    @if (isOpen)
    {
        <div class="chat-window">
            <div class="chat-header">
                <span>@L["Title"]</span>
                <button class="chat-close" @onclick="ToggleChat">✕</button>
            </div>
            <div class="chat-messages" id="widgetMessages">
                @foreach (var msg in messages)
                {
                    <div class="message @(msg.IsUser ? "user" : "bot")">
                        <strong>@(msg.IsUser ? L["You"] : L["Bot"]):</strong>
                        <!-- [ИЗМЕНЕНО] Выводим текст как MarkupString для поддержки кликабельных ссылок -->
                        <span>@((MarkupString)FormatMessage(msg.Text))</span>
                    </div>
                }
            </div>
            <div class="chat-input">
                <input @bind="userInput"
                       @bind:event="oninput"
                       placeholder="@L["Placeholder"]"
                       @onkeyup="OnKeyUp"
                       class="form-control form-control-sm" />
                <button @onclick="SendMessage" class="btn btn-primary btn-sm" disabled="@isLoading">
                    @(isLoading ? "..." : "➤")
                </button>
            </div>
        </div>
    }
</div>

@code {
    private bool isOpen = false;
    private List<ChatMessage> messages = new();
    private string userInput = "";
    private bool isLoading = false;

    protected override void OnInitialized()
    {
        // Локализованное приветствие при первом запуске
        messages.Add(new ChatMessage { Text = L["Greeting"], IsUser = false });
    }

    private async Task ToggleChat()
    {
        isOpen = !isOpen;
        StateHasChanged();

        if (isOpen)
        {
            // Небольшая пауза, чтобы окно чата успело отрендериться в браузере перед прокруткой
            await Task.Delay(50);
            await ScrollToBottom();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isLoading) return;

        var userMsg = userInput;
        messages.Add(new ChatMessage { Text = userMsg, IsUser = true });
        userInput = "";
        isLoading = true;
        StateHasChanged();

        await ScrollToBottom(); // Прокручиваем сразу после отправки пользователя

        try
        {
            var reply = await ChatService.GetBotReplyAsync(userMsg);
            messages.Add(new ChatMessage { Text = reply, IsUser = false });
        }
        catch (Exception ex)
        {
            messages.Add(new ChatMessage { Text = $"{L["Error"]}: {ex.Message}", IsUser = false });
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
            await ScrollToBottom(); // Прокручиваем после ответа бота
        }
    }

    private async Task ScrollToBottom()
    {
        // Даем Blazor 50 миллисекунд, чтобы полностью отрисовать новые сообщения в DOM
        await Task.Delay(50);
        await JsRuntime.InvokeVoidAsync("scrollToBottom", "widgetMessages");
    }

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isLoading && !string.IsNullOrWhiteSpace(userInput))
        {
            await SendMessage();
        }
    }

    // [НОВОЕ] Вспомогательный метод для поиска и оборачивания ссылок
    private string FormatMessage(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return string.Empty;

        try
        {
            // 1. Безопасно экранируем исходный HTML-текст от XSS
            var escapedText = System.Web.HttpUtility.HtmlEncode(text);

            // 2. [НОВОЕ] Преобразуем Markdown жирный шрифт **текст** в HTML-тег <strong>текст</strong>
            // Нам нужно обработать это до ссылок, чтобы убрать звездочки из разметки
            var boldRegex = new Regex(@"\*\*([^*]+)\*\*", RegexOptions.Compiled);
            escapedText = boldRegex.Replace(escapedText, "<strong>$1</strong>");

            // 3. Сначала парсим Markdown-ссылки вида: [Анкор](https://...)
            var markdownLinkRegex = new Regex(@"\[([^\]]+)\]\((https?://[^\s)]+)\)", RegexOptions.Compiled | RegexOptions.IgnoreCase);

            escapedText = markdownLinkRegex.Replace(escapedText, match =>
                    {
                        var linkText = match.Groups[1].Value;
                        var url = System.Web.HttpUtility.HtmlDecode(match.Groups[2].Value);
                        return $"<a href=\"{url}\" target=\"_blank\" style=\"color: #00e5ff; text-decoration: underline; font-weight: bold;\">{linkText}</a>";
                    });

            // 4. Затем парсим оставшиеся голые ссылки (только те, которые еще НЕ обернуты в тег <a>)
            // Исключаем попадание точки, запятой или скобок на конце ссылки, а также тегов <strong> вокруг
            var bareUrlRegex = new Regex(@"(?<!href=\x22)(?<!\x3e)(https?://[^\s<]+?)(?=[.,!?]?(?:\s|$|<|<strong>|<\/strong>))", RegexOptions.Compiled | RegexOptions.IgnoreCase);

            escapedText = bareUrlRegex.Replace(escapedText, match =>
                    {
                        var url = System.Web.HttpUtility.HtmlDecode(match.Value);
                        return $"<a href=\"{url}\" target=\"_blank\" style=\"color: #00e5ff; text-decoration: underline; font-weight: bold;\">{url}</a>";
                    });

            return escapedText;
        }
        catch
        {
            // Если произошла непредвиденная ошибка, возвращаем исходный текст, чтобы не сломать чат
            return text ?? string.Empty;
        }
    }

    private class ChatMessage
    {
        public string? Text { get; set; }
        public bool IsUser { get; set; }
    }
}