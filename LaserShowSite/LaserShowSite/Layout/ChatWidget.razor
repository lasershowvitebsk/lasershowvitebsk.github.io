@using LaserShowSite.Services
@using Microsoft.Extensions.Localization
@using System.Text.RegularExpressions
@using System.Globalization
@inject ChatService ChatService
@inject IJSRuntime JsRuntime
@inject IStringLocalizer<ChatWidget> L

<div class="chat-widget">
    <button class="chat-toggle" @onclick="ToggleChat">
        @if (isOpen)
        {
            <span>✕</span>
        }
        else
        {
            <span>💬</span>
        }
    </button>

    @if (isOpen)
    {
        <div class="chat-window">
            <div class="chat-header">
                <span>@L["Title"]</span>
                <button class="chat-close" @onclick="ToggleChat">✕</button>
            </div>

            <div class="chat-messages" id="widgetMessages">
                @foreach (var msg in messages)
                {
                    <div class="message @(msg.IsUser ? "user" : "bot")">
                        <strong>@(msg.IsUser ? L["You"] : L["Bot"]):</strong>
                        <span>@((MarkupString)FormatMessage(msg.Text))</span>
                    </div>
                }
            </div>

            <!-- Чипсы — всегда видны, блокируются во время загрузки -->
            <div class="chat-chips">
                <button class="chip"
                        disabled="@isLoading"
                        @onclick='() => SendChip("prices")'>
                    💰 @L["ChipPrices"]
                </button>
                <button class="chip"
                        disabled="@isLoading"
                        @onclick='() => SendChip("stories")'>
                    🎬 @L["ChipStories"]
                </button>
                <button class="chip"
                        disabled="@isLoading"
                        @onclick='() => SendChip("order")'>
                    📋 @L["ChipOrder"]
                </button>
                <button class="chip"
                        disabled="@isLoading"
                        @onclick='() => SendChip("contacts")'>
                    📞 @L["ChipContacts"]
                </button>
            </div>

            <div class="chat-input">
                <input @bind="userInput"
                       @bind:event="oninput"
                       placeholder="@L["Placeholder"]"
                       @onkeyup="OnKeyUp"
                       class="form-control form-control-sm" />
                <button @onclick="SendMessage"
                        class="btn btn-primary btn-sm"
                        disabled="@isLoading">
                    @(isLoading ? "..." : "➤")
                </button>
            </div>
        </div>
    }
</div>

@code {
    private bool isOpen = false;
    private List<ChatMessage> messages = new();
    private string userInput = "";
    private bool isLoading = false;

    private string currentLanguage =>
        CultureInfo.CurrentCulture.Name.StartsWith("ru", StringComparison.OrdinalIgnoreCase)
            ? "ru"
            : "en";

    protected override void OnInitialized()
    {
        messages.Add(new ChatMessage { Text = L["Greeting"], IsUser = false });
    }

    private async Task ToggleChat()
    {
        isOpen = !isOpen;
        StateHasChanged();

        if (isOpen)
        {
            await Task.Delay(50);
            await ScrollToBottom();
        }
    }

    // Обычная отправка текстового сообщения
    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isLoading) return;

        var userMsg = userInput;
        messages.Add(new ChatMessage { Text = userMsg, IsUser = true });
        userInput = "";
        isLoading = true;
        StateHasChanged();

        await ScrollToBottom();

        try
        {
            var reply = await ChatService.GetBotReplyAsync(userMsg, currentLanguage);
            messages.Add(new ChatMessage { Text = reply, IsUser = false });
        }
        catch (Exception ex)
        {
            messages.Add(new ChatMessage
            {
                Text = $"{L["Error"]}: {ex.Message}",
                IsUser = false
            });
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    // Отправка через чипс — мгновенный ответ без LLM
    private async Task SendChip(string chipId)
    {
        if (isLoading) return;

        var label = chipId switch
        {
            "prices" => L["ChipPrices"].Value,
            "stories" => L["ChipStories"].Value,
            "order" => L["ChipOrder"].Value,
            "contacts" => L["ChipContacts"].Value,
            _ => chipId
        };

        messages.Add(new ChatMessage { Text = label, IsUser = true });
        isLoading = true;
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            var reply = await ChatService.GetChipReplyAsync(chipId, currentLanguage);
            messages.Add(new ChatMessage { Text = reply, IsUser = false });
        }
        catch (Exception ex)
        {
            messages.Add(new ChatMessage
            {
                Text = $"{L["Error"]}: {ex.Message}",
                IsUser = false
            });
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(50);
        await JsRuntime.InvokeVoidAsync("scrollToBottom", "widgetMessages");
    }

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isLoading && !string.IsNullOrWhiteSpace(userInput))
        {
            await SendMessage();
        }
    }

    private string FormatMessage(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return string.Empty;

        try
        {
            var escapedText = System.Web.HttpUtility.HtmlEncode(text);

            // **жирный** → <strong>
            var boldRegex = new Regex(@"\*\*([^*]+)\*\*", RegexOptions.Compiled);
            escapedText = boldRegex.Replace(escapedText, "<strong>$1</strong>");

            // *жирный* → <strong>
            var boldSingleRegex = new Regex(@"\*([^*\n]+)\*", RegexOptions.Compiled);
            escapedText = boldSingleRegex.Replace(escapedText, "<strong>$1</strong>");

            // [текст](url) → ссылка
            var markdownLinkRegex = new Regex(
                @"\[([^\]]+)\]\((https?://[^\s)]+)\)",
                RegexOptions.Compiled | RegexOptions.IgnoreCase
            );
            escapedText = markdownLinkRegex.Replace(escapedText, match =>
            {
                var linkText = match.Groups[1].Value;
                var linkUrl = System.Web.HttpUtility.HtmlDecode(match.Groups[2].Value);
                return $"<a href=\"{linkUrl}\" target=\"_blank\" " +
                       $"style=\"color:#00e5ff;text-decoration:underline;font-weight:bold;\">" +
                       $"{linkText}</a>";
            });

            // Голые URL → ссылка
            var bareUrlRegex = new Regex(
                @"(?<!href="")(?<!\x3e)(https?://[^\s<]+?)(?=[.,!?]?(?:\s|$|<))",
                RegexOptions.Compiled | RegexOptions.IgnoreCase
            );
            escapedText = bareUrlRegex.Replace(escapedText, match =>
            {
                var linkUrl = System.Web.HttpUtility.HtmlDecode(match.Value);
                return $"<a href=\"{linkUrl}\" target=\"_blank\" " +
                       $"style=\"color:#00e5ff;text-decoration:underline;font-weight:bold;\">" +
                       $"{linkUrl}</a>";
            });

            // Переносы строк → <br>
            escapedText = escapedText.Replace("\n", "<br>");

            return escapedText;
        }
        catch
        {
            return text ?? string.Empty;
        }
    }

    private class ChatMessage
    {
        public string? Text { get; set; }
        public bool IsUser { get; set; }
    }
}